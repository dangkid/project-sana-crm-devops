# ===========================================
# Git Ignore - SANA Project
# ===========================================

# Environment variables
.env
.env.local
.env.*.local

# Dependencies
node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock

# Build outputs
dist/
build/
out/
*.tgz

# IDE and Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.env.swp
.editorconfig

# OS
Thumbs.db
.DS_Store
*.pid
*.pid.lock

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.seed
*.pid.lock

# Testing
coverage/
.nyc_output/

# Docker
.dockerignore
docker-compose.override.yml

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.backup

# Security
.git-credentials
*.key
*.pem
*.p12
*.pfx
private/

# Certificates (local development only)
nginx/ssl/*.pem
nginx/ssl/*.key
nginx/ssl/*.crt
nginx/ssl/*.csr

# Node modules from container
!docker-compose.yml
!Dockerfile
!.dockerignore

# IDE specific
.vscode/settings.json
.vscode/extensions.json

# OS generated
*.swp
*.swo
*~
.project
.buildpath

# Misc
*.orig
*.patch
*.diff

# Package managers
npm-shrinkwrap.json
pnpm-lock.yaml

# Git
.git/
.gitattributes

# Systemd
*.service
*.timer

# Misc OS files
*.thumbs
*.lnk

# Development database
*.db
*.sqlite
*.sqlite3

