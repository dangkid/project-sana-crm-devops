# ============================================
# SANA - Centro Terapéutico Integral
# Archivo de Configuración Ambiental
# ============================================

# ========== SERVIDOR NGINX ==========
SERVER_NAME=sana-clinica.com
SERVER_ALIAS=www.sana-clinica.com
PORT=80
HTTPS_PORT=443

# ========== ENTORNO ==========
ENVIRONMENT=production
NODE_ENV=production
DEBUG=false

# ========== ZONA HORARIA ==========
TZ=America/Bogota

# ========== CHATWOOT CONFIGURATION ==========
# Descomenta y configura cuando integres Chatwoot

# CHATWOOT_ENABLED=true
# CHATWOOT_DOMAIN=app.chatwoot.com
# CHATWOOT_WEBSITE_TOKEN=your_website_token_here
# CHATWOOT_BASE_URL=https://app.chatwoot.com

# ========== SSL/HTTPS (Futuro) ==========
# SSL_ENABLED=false
# SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
# SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# ========== LOGGING ==========
LOG_LEVEL=info
ACCESS_LOG_ENABLED=true
ERROR_LOG_ENABLED=true

# ========== DOCKER ==========
COMPOSE_PROJECT_NAME=sana-clinica
CONTAINER_NAME=sana-clinica-web
IMAGE_NAME=sana-clinica
IMAGE_TAG=latest

# ========== HEALTH CHECK ==========
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=3
HEALTH_CHECK_RETRIES=3

# ========== PERFORMANCE ==========
GZIP_ENABLED=true
GZIP_LEVEL=6
CACHE_ENABLED=true
CACHE_DAYS=30

# ========== SEGURIDAD ==========
X_FRAME_OPTIONS=SAMEORIGIN
X_CONTENT_TYPE_OPTIONS=nosniff
X_XSS_PROTECTION=true
CONTENT_SECURITY_POLICY=true

# ========== CONTACTO Y METADATA ==========
CLINIC_NAME=SANA - Centro Terapéutico Integral
CLINIC_EMAIL=contacto@sana-clinica.com
CLINIC_PHONE=+57 XXX XXXX XXX
CLINIC_ADDRESS=Tu Dirección Aquí
CLINIC_CITY=Ciudad
CLINIC_COUNTRY=País

# ========== REDES SOCIALES ==========
SOCIAL_FACEBOOK=https://facebook.com/sana-clinica
SOCIAL_INSTAGRAM=https://instagram.com/sana-clinica
SOCIAL_WHATSAPP=https://wa.me/57XXXXXXXXXX
SOCIAL_LINKEDIN=https://linkedin.com/company/sana-clinica

# ========== SERVICIOS ==========
SERVICE_PSYCHOLOGY=true
SERVICE_EMOTIONAL=true
SERVICE_REFLEXOTHERAPY=true
SERVICE_PODOLOGY=true
SERVICE_WORKSHOPS=true
SERVICE_CONSULTATION=true

# ========== NOTIFICACIONES ==========
NOTIFICATION_EMAIL_ON_FORM=true
NOTIFICATION_SLACK_ENABLED=false
NOTIFICATION_SLACK_WEBHOOK=

# ========== ANALYTICS ==========
GOOGLE_ANALYTICS_ID=
HOTJAR_ID=
FACEBOOK_PIXEL_ID=

# ========== BACKUPS ==========
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30

# ========== DESARROLLO ==========
# Usar solo en desarrollo local
# DEV_HOT_RELOAD=true
# DEV_SOURCE_MAPS=true
